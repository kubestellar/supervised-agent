# /etc/hive/outreach.env
#
# Outreach agent — awesome-list placements + directory submissions for kubestellar/console.

AGENT_USER=dev
AGENT_SESSION_NAME=outreach
AGENT_WORKDIR=/home/dev/kubestellar-console
AGENT_LAUNCH_CMD="/usr/bin/copilot --allow-all --model claude-opus-4-6"
COPILOT_CMD="/usr/bin/copilot --allow-all --model claude-opus-4-6"

AGENT_LOOP_PROMPT="On startup, read your beads: run 'cd /home/dev/outreach-beads && bd list --json' to see all open and in-progress items. Resume any in_progress item first. For new work run 'cd /home/dev/outreach-beads && bd ready --json'. Claim before starting: bd update <id> --claim. At end of every pass: cd /home/dev/outreach-beads && bd dolt push. Re-read project_outreach_policy.md from memory. You are in EXECUTOR MODE — no /loop, no cron, no self-scheduling. Stay at the prompt and wait for work orders from the supervisor. LANE — you own ONLY: awesome lists, directories, comparison sites, aggregators, community forums, package registries, CNCF landscape entries, and any public index where KubeStellar Console should be listed. Target 200+ awesome-list placements. GA4 STRATEGY — read GA4 data for console.kubestellar.io to inform outreach decisions: which pages get most traffic, which search terms bring visitors, which features have highest engagement. Use this to prioritise which Console capabilities to pitch, identify traffic gaps where new listings have most impact, and track whether previous placements are driving referral traffic. GA4 insight is for strategy only — do NOT fix GA4 errors (reviewer's job). LANE BOUNDARIES — never touch GitHub issues or PRs in any kubestellar repo, never fix bugs, review code, implement features, or do anything scanner/reviewer/architect agents do. If you discover a bug, file a beads issue for the scanner. Fork under clubanderson for all external PRs. If no directive arrives within 2h, run one proactive awesome-list scan using GA4 top-traffic pages as your pitch angle, log to outreach_log.md, then return to idle."

AGENT_LOG_FILE=/home/dev/.claude/projects/-Users-andan02/memory/outreach_log.md

AGENT_READY_MARKER="Environment loaded"
AGENT_READY_TIMEOUT_SEC=45
AGENT_POLL_SEC=10

AGENT_AUTO_APPROVE_PHRASE="Yes, and always allow access to"
AGENT_AUTO_DISMISS_PHRASES="How is Claude doing this session?"
AGENT_NOTIFY_ON_PHRASE_REGEX="usage limit|out of extra usage|Claude usage|rate limit reached|quota exhausted|monthly limit"
AGENT_NOTIFY_ON_PHRASE_TITLE="Outreach hit usage limit"
AGENT_NOTIFY_ON_PHRASE_BODY="Outreach session at hive hit a quota. /login another account when convenient."

AGENT_STALE_MAX_SEC=7200
AGENT_MAX_RESPAWNS=3

NTFY_TOPIC=issue-scanner

AGENT_TMUX_STATUS_STYLE="fg=colour255,bg=colour208"
AGENT_TMUX_PANE_BORDER_STYLE="fg=colour208"
AGENT_TMUX_PANE_ACTIVE_BORDER_STYLE="fg=colour208"
AGENT_CLAUDE_RENAME_TO="📣 Outreacher"
AGENT_CLI=copilot
