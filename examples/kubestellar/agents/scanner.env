# Scanner agent — issue triage + GitHub scanning for kubestellar/console.
# Uses unified supervisor.sh with rate-limit failover enabled.

AGENT_USER=dev
AGENT_SESSION_NAME=scanner
AGENT_WORKDIR=/home/dev/kubestellar-console
AGENT_LAUNCH_CMD="agent-launch.sh --backend copilot --model claude-sonnet-4-6"
AGENT_CLI=copilot

AGENT_LOOP_PROMPT="You are the KubeStellar Scanner in EXECUTOR MODE — no self-scheduling. On startup, read your beads: run 'cd /home/dev/scanner-beads && bd list --json' to see all open and in-progress items. Resume any in_progress item first. For new work run 'cd /home/dev/scanner-beads && bd ready --json'. Claim before starting: bd update <id> --claim. At end of every pass: bd dolt push. Stay at the prompt and wait for work orders from the supervisor."

AGENT_STALE_MAX_SEC=1800
AGENT_MAX_RESPAWNS=3

AGENT_POLL_SEC=10
AGENT_AUTO_APPROVE_PHRASE="Yes, and always allow access to"
AGENT_AUTO_DISMISS_PHRASES="How is Claude doing this session?"
AGENT_NOTIFY_ON_PHRASE_REGEX="usage limit|out of extra usage|Claude usage|rate limit reached|quota exhausted|monthly limit"
AGENT_NOTIFY_ON_PHRASE_TITLE="Scanner hit usage limit"
AGENT_NOTIFY_ON_PHRASE_BODY="Scanner session at hive hit a CLI quota. Switching backends if failover is enabled."

AGENT_TMUX_STATUS_STYLE="bg=colour24,fg=white"
AGENT_TMUX_PANE_BORDER_STYLE="fg=colour24"
AGENT_TMUX_PANE_ACTIVE_BORDER_STYLE="fg=colour45"
AGENT_CLAUDE_RENAME_TO=Scanner

# Rate-limit failover: switch between copilot and claude on CLI exhaustion
AGENT_RATE_LIMIT_FAILOVER=true
AGENT_FAILOVER_CMD="agent-launch.sh --backend claude --model claude-opus-4-6"
AGENT_FAILOVER_CLI=claude
AGENT_RATE_LIMIT_COOLDOWN_SEC=300
AGENT_PIN_CLI=true
AGENT_PIN_MODEL=true
