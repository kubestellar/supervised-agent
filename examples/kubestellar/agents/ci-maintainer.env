# /etc/hive/ci-maintainer.env
#
# CI-Maintainer agent — regression guardian + UX improver for ${PROJECT_PRIMARY_REPO}.
# Deployed via: sudo ./install.sh --instance ci-maintainer  (from hive repo)
# Policy lives in memory/project_ci-maintainer_policy.md on the shared Syncthing dir.

AGENT_USER=dev
AGENT_SESSION_NAME=ci-maintainer
AGENT_WORKDIR=${AGENTS_WORKDIR}
AGENT_LAUNCH_CMD="agent-launch.sh --backend copilot --model claude-sonnet-4-6"
AGENT_CLI=copilot

# Short loop prompt — the real policy is in project_ci-maintainer_policy.md, re-read
# every iteration at Step 0.
AGENT_LOOP_PROMPT="On startup, read your beads: run 'cd /home/dev/ci-maintainer-beads && bd list --json' to see all open and in-progress items. Resume any in_progress item first. For new work run 'cd /home/dev/ci-maintainer-beads && bd ready --json'. Claim before starting: bd update <id> --claim. At end of every pass: bd dolt push. Re-read project_ci-maintainer_policy.md from memory. You are in EXECUTOR MODE — no self-scheduling, no /loop cron. Then stay at the prompt and wait for work orders from the supervisor. If no directive arrives within 45 min, run one proactive nightly regression + CodeQL drain pass, log it to ci-maintainer_log.md, then return to idle."

AGENT_LOG_FILE=/home/dev/.claude/projects/-Users-andan02/memory/ci-maintainer_log.md

AGENT_READY_MARKER="Environment loaded"
AGENT_READY_TIMEOUT_SEC=45
AGENT_POLL_SEC=10

# Same auto-approve / auto-dismiss / notify-on-phrase patterns as the scanner.
AGENT_AUTO_APPROVE_PHRASE="Yes, and always allow access to"
AGENT_AUTO_DISMISS_PHRASES="How is Claude doing this session?"
AGENT_NOTIFY_ON_PHRASE_REGEX="usage limit|out of extra usage|Claude usage|rate limit reached|quota exhausted|monthly limit"
AGENT_NOTIFY_ON_PHRASE_TITLE="CI-Maintainer hit usage limit"
AGENT_NOTIFY_ON_PHRASE_BODY="CI-Maintainer session at hive hit a quota. /login another account when convenient. Stale-claim sweep on next iteration will recover in-flight work."

# CI-Maintainer stalls faster than scanner (less work per iteration) — tighter
# staleness threshold so the healthcheck respawns sooner if the loop gets stuck.
AGENT_STALE_MAX_SEC=2400
AGENT_MAX_RESPAWNS=3


# Display persistence across respawns
AGENT_TMUX_STATUS_STYLE="bg=colour22,fg=white"
AGENT_TMUX_PANE_BORDER_STYLE="fg=colour22"
AGENT_TMUX_PANE_ACTIVE_BORDER_STYLE="fg=colour82"
AGENT_CLAUDE_RENAME_TO=CI-Maintainer
AGENT_PIN_CLI=true
AGENT_PIN_MODEL=true
