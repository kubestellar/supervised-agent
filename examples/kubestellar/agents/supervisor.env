# /etc/hive/supervisor.env — Hive Supervisor agent config
# Loaded by: hive.service (systemd) and start_supervisor() in hive.sh

AGENT_USER=dev
AGENT_SESSION_NAME=supervisor
AGENT_WORKDIR=/home/dev/hive-supervisor
AGENT_LAUNCH_CMD="agent-launch.sh --backend copilot --model claude-sonnet-4-6"
AGENT_CLI=copilot

# Copilot shows "Environment loaded" when ready; Claude Code shows "bypass permissions on"
AGENT_READY_MARKER="Environment loaded"
AGENT_READY_TIMEOUT_SEC=45
AGENT_POLL_SEC=10

# Supervisor beads — separate from all worker agents
BEADS_SUPERVISOR_DIR=/home/dev/supervisor-beads

AGENT_LOOP_PROMPT="You are the Hive Supervisor. STEP 0: pull latest hive repo: git -C ${HIVE_REPO} pull --rebase origin main. Then cp ${HIVE_REPO}/examples/kubestellar/agents/supervisor-CLAUDE.md ${AGENTS_WORKDIR}/.github/copilot-instructions.md. STEP 1: re-read your policy file ${AGENTS_WORKDIR}/.github/copilot-instructions.md. STEP 2: hive status. STEP 3: cd ${BEADS_BASE}/supervisor-beads && bd list --json. STEP 4: check all agent panes (scanner, ci-maintainer, architect, outreach — adjust list per your deployment). STEP 5: kick idle agents with full startup messages from ${HIVE_REPO}/bin/kick-agents.sh. STEP 6: report status. You are in EXECUTOR MODE — no self-scheduling. Stay at the prompt and wait for work orders from the operator after completing these steps."

AGENT_LOG_FILE=/home/dev/.local/state/hive/supervisor-heartbeat.log
AGENT_STALE_MAX_SEC=3600
AGENT_MAX_RESPAWNS=3

AGENT_AUTO_APPROVE_PHRASE="Yes, and always allow access to"
AGENT_AUTO_DISMISS_PHRASES="How is Claude doing this session?"
AGENT_NOTIFY_ON_PHRASE_REGEX="usage limit|out of extra usage|rate limit reached|quota exhausted|monthly limit"
AGENT_NOTIFY_ON_PHRASE_TITLE="Supervisor hit usage limit"
AGENT_NOTIFY_ON_PHRASE_BODY="Supervisor session on hive hit a quota. Login with another account when convenient."


AGENT_TMUX_STATUS_STYLE="bg=colour196,fg=white"
AGENT_TMUX_PANE_BORDER_STYLE="fg=colour196"
AGENT_TMUX_PANE_ACTIVE_BORDER_STYLE="fg=colour226"
AGENT_CLAUDE_RENAME_TO=Supervisor
AGENT_PIN_CLI=true
AGENT_PIN_MODEL=true
