# /etc/hive/architect.env
#
# Architect / ideator agent — architectural RFCs, GA4-driven feature ideas,
# help-wanted grooming, cross-cutting refactor plans.
# Policy lives at memory/project_architect_policy.md.

AGENT_USER=dev
AGENT_SESSION_NAME=architect
AGENT_WORKDIR=/home/dev/kubestellar-console
AGENT_LAUNCH_CMD="agent-launch.sh --backend copilot --model claude-opus-4-6"
AGENT_CLI=copilot

AGENT_LOOP_PROMPT="On startup, read your beads: run 'cd /home/dev/architect-beads && bd list --json' to see all open and in-progress items. Resume any in_progress item first. For new work run 'cd /home/dev/architect-beads && bd ready --json'. Claim before starting: bd update <id> --claim. At end of every pass: bd dolt push. You are the Architect in EXECUTOR MODE — no self-scheduling, no /loop cron. Re-read project_architect_policy.md from memory. Stay at the prompt and wait for work orders from the supervisor. If no directive arrives within 2h, run one proactive refactor/perf scan, log to architect_log.md, then return to idle."

AGENT_LOG_FILE=/home/dev/.claude/projects/-Users-andan02/memory/architect_log.md

AGENT_READY_MARKER="Environment loaded"
AGENT_READY_TIMEOUT_SEC=45
AGENT_POLL_SEC=10

AGENT_AUTO_APPROVE_PHRASE="Yes, and always allow access to"
AGENT_AUTO_DISMISS_PHRASES="How is Claude doing this session?"
AGENT_NOTIFY_ON_PHRASE_REGEX="usage limit|out of extra usage|Claude usage|rate limit reached|quota exhausted|monthly limit"
AGENT_NOTIFY_ON_PHRASE_TITLE="Architect agent hit usage limit"
AGENT_NOTIFY_ON_PHRASE_BODY="Architect session at hive hit a quota. /login another account when convenient."

# Feature agent stalls easily (long thinking phases). More generous than scanner/reviewer.
AGENT_STALE_MAX_SEC=9000
AGENT_MAX_RESPAWNS=3


# Display persistence across respawns
AGENT_TMUX_STATUS_STYLE="bg=colour53,fg=white"
AGENT_TMUX_PANE_BORDER_STYLE="fg=colour53"
AGENT_TMUX_PANE_ACTIVE_BORDER_STYLE="fg=colour165"
AGENT_CLAUDE_RENAME_TO=Architect
AGENT_PIN_CLI=true
AGENT_PIN_MODEL=true
