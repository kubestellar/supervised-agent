# /etc/hive/tester.env
#
# Tester agent — test strategist that builds coverage from current to target.
# Deployed via: sudo ./install.sh --instance tester  (from hive repo)

AGENT_USER=dev
AGENT_SESSION_NAME=tester
AGENT_WORKDIR=${AGENTS_WORKDIR}
AGENT_LAUNCH_CMD="agent-launch.sh --backend claude --model claude-sonnet-4-6"
AGENT_CLI=claude

AGENT_LOOP_PROMPT="On startup, read your beads: run 'cd /home/dev/tester-beads && bd list --json' to see all open and in-progress items. Resume any in_progress item first. For new work run 'cd /home/dev/tester-beads && bd ready --json'. Claim before starting: bd update <id> --claim. At end of every pass: bd dolt push. You are in EXECUTOR MODE — no self-scheduling, no /loop cron. Then stay at the prompt and wait for work orders from the supervisor. If no directive arrives within 45 min, run one proactive coverage gap analysis pass, log it to tester_log.md, then return to idle."

AGENT_LOG_FILE=/home/dev/.claude/projects/-Users-andan02/memory/tester_log.md

AGENT_READY_MARKER="Environment loaded"
AGENT_READY_TIMEOUT_SEC=45
AGENT_POLL_SEC=10

AGENT_AUTO_APPROVE_PHRASE="Yes, and always allow access to"
AGENT_AUTO_DISMISS_PHRASES="How is Claude doing this session?"
AGENT_NOTIFY_ON_PHRASE_REGEX="usage limit|out of extra usage|Claude usage|rate limit reached|quota exhausted|monthly limit"
AGENT_NOTIFY_ON_PHRASE_TITLE="Tester hit usage limit"
AGENT_NOTIFY_ON_PHRASE_BODY="Tester session at hive hit a quota. /login another account when convenient."

AGENT_STALE_MAX_SEC=2400
AGENT_MAX_RESPAWNS=3

AGENT_TMUX_STATUS_STYLE="bg=colour54,fg=white"
AGENT_TMUX_PANE_BORDER_STYLE="fg=colour54"
AGENT_TMUX_PANE_ACTIVE_BORDER_STYLE="fg=colour141"
AGENT_CLAUDE_RENAME_TO=Tester
AGENT_PIN_CLI=true
AGENT_PIN_MODEL=true
