# /etc/supervised-agent/agent.env
#
# Configuration for the supervised-agent runtime. systemd loads this file via
# EnvironmentFile= for every unit. Change any value, then either:
#   sudo systemctl stop supervised-agent && \
#   sudo -u "$AGENT_USER" tmux kill-session -t "$AGENT_SESSION_NAME"; \
#   sudo systemctl start supervised-agent
# (plain `systemctl restart` alone doesn't force a session respawn — tmux
# outlives the supervisor, so the new supervisor sees a "healthy" old session
# and does nothing.)

# ---- REQUIRED ---------------------------------------------------------------

# Unix user the agent runs as. NOT root.
AGENT_USER=dev

# Working directory for the agent process (claude's cwd).
AGENT_WORKDIR=/home/dev/my-project

# Shell command that launches the agent in the foreground.
# Must be something that RENDERS AN INTERACTIVE TUI — not a one-shot print mode.
# For Claude Code, do NOT pass -p; it exits after one reply.
# IMPORTANT: quote multi-word values. install.sh sources this file with
# `set -a; . "$ENV_FILE"` so any unquoted flags get parsed as commands.
AGENT_LAUNCH_CMD="/usr/bin/claude --dangerously-skip-permissions --model claude-opus-4-6"

# The text sent to the agent after its TUI is ready. For Claude Code this is
# almost always a /loop command. Keep it short and point the agent at a policy
# file for detailed instructions so you can edit policy without respawning.
# IMPORTANT: quote the whole value (same shell-parsing reason as above).
AGENT_LOOP_PROMPT="/loop 15m Follow every rule in scanner-policy.md from memory. At the START of each iteration, print SCAN_START_ET=\$(TZ=America/New_York date \"+%Y-%m-%d %H:%M:%S %Z\"). At the END, print SCAN_END_ET and NEXT_RUN_ET. All timestamps in America/New_York."

# Absolute path the agent appends its heartbeat to. Healthcheck watches this
# file's mtime. The agent MUST write to it on every iteration (put that
# requirement in your policy file).
AGENT_LOG_FILE=/home/dev/.local/state/supervised-agent/heartbeat.log

# ---- OPTIONAL ---------------------------------------------------------------

# tmux session name.
AGENT_SESSION_NAME=supervised-agent

# String the supervisor waits for in the pane before sending AGENT_LOOP_PROMPT.
# For Claude Code v2.x this is the footer hint "bypass permissions on".
# If your agent's footer changes, update this or the /loop will never fire.
AGENT_READY_MARKER=bypass permissions on

# Seconds to wait for the ready marker before giving up (supervisor retries
# on the next poll tick).
AGENT_READY_TIMEOUT_SEC=45

# Supervisor health-check interval, in seconds.
AGENT_POLL_SEC=10

# If this phrase appears in the pane, the supervisor auto-sends Down+Enter to
# select the "always allow" option. Claude Code's sensitive-file prompt is:
#   1. Yes
#   2. Yes, and always allow access to memory/ from this project
#   3. No
# Matching the option-2 text is unique enough to avoid false positives.
# Leave blank to disable auto-approval.
AGENT_AUTO_APPROVE_PHRASE=Yes, and always allow access to

# Newline-separated list of phrases to dismiss with a single Escape keypress
# whenever they appear. Use this for non-blocking prompts you don't want to
# engage with (e.g. Claude Code's post-session feedback poll, which otherwise
# sits in the input area and stops the next /loop firing from submitting).
# Each line is matched as a fixed string (grep -F); put one phrase per line
# inside single quotes to preserve newlines in systemd EnvironmentFile syntax.
AGENT_AUTO_DISMISS_PHRASES='How is Claude doing this session?'

# Extended-regex pattern; if matched in the pane, supervisor pushes a high-
# priority ntfy alert. Does NOT take any active recovery action. Use this for
# events where you want to know about the condition but prefer to handle it
# yourself (e.g. Claude Max/Pro usage limits if you manage logins manually).
# Set NTFY_TOPIC as well or this is a no-op. Leave blank to disable.
AGENT_NOTIFY_ON_PHRASE_REGEX=usage limit|out of extra usage|Claude usage|rate limit reached|quota exhausted|monthly limit
AGENT_NOTIFY_ON_PHRASE_TITLE=Agent hit usage limit
AGENT_NOTIFY_ON_PHRASE_BODY=Session is blocked on a quota. Log in with another account or wait for the reset; the supervisor will NOT change credentials on its own. Work in flight is preserved in whatever ledger the agent uses (see your policy).

# Seconds of heartbeat silence before healthcheck considers the agent stalled.
# Default is generous: typical /loop cron cadence is 15 min, scans take 5-10
# min, so 30 min of silence is real trouble.
AGENT_STALE_MAX_SEC=1800

# After this many consecutive respawns with no recovery, healthcheck sends an
# urgent ntfy push and stops auto-respawning (prevents thrashing when the
# underlying problem is deeper — auth, quota, upstream API down).
AGENT_MAX_RESPAWNS=3

# ntfy.sh topic for push alerts. Leave blank/unset to run without push.
# Pick an unguessable string (uuidgen recommended). Anyone who knows the
# topic can read your alerts and send fake ones.
NTFY_TOPIC=

# ntfy server (override for self-hosted).
NTFY_SERVER=https://ntfy.sh
