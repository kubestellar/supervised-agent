# hive-project.yaml — Project configuration for Hive multi-agent orchestration
#
# This file is the single source of truth for all project-specific values.
# Place at /etc/hive/hive-project.yaml or set HIVE_PROJECT_CONFIG env var.
#
# All scripts read this file via bin/hive-config.sh. If missing, scripts fall
# back to built-in defaults (which may not match your project).

project:
  name: "My Project"                    # displayed in dashboard header
  org: "myorg"                          # GitHub organization
  primary_repo: "myorg/myapp"           # main repo for CI, health checks, metrics
  repos:                                # all repos managed by hive agents
    - myorg/myapp
    - myorg/docs
  ai_author: "my-bot-account"           # GitHub username for AI-authored PRs
  website: ""                           # project website (optional, used by outreach)

agents:
  enabled:                              # which agents to run
    - supervisor
    - scanner
    - reviewer
    # - architect                       # uncomment to enable
    # - outreach                        # uncomment to enable
  beads_base: "/home/dev"               # beads dirs = {beads_base}/{agent}-beads
  workdir: "/home/dev/myapp"            # default agent working directory

health_checks:
  # Nightly workflows — checked by reviewer agent and dashboard health panel
  workflows:
    # - name: "Nightly Test Suite"
    #   key: nightly                    # JSON output key (auto-generated from name if omitted)
    #   type: nightly
    # - name: "Weekly Coverage Review"
    #   key: weekly
    #   type: weekly
  # Deploy jobs — checked from the CI workflow run
  ci_workflow: ""                       # name of CI/deploy workflow (e.g., "Build and Deploy")
  deploy_jobs: []                       # job names within ci_workflow to check
    # - name: "deploy-staging"
    # - name: "deploy-prod"
  # Perf workflows — worst-of check
  perf_workflows: []
    # - "Perf — response time"
  # Homebrew (optional)
  brew:
    tap_repo: ""                        # e.g., "myorg/homebrew-tap"
    formula: ""                         # e.g., "myapp.rb"
  # Helm chart (optional)
  helm:
    chart_path: ""                      # e.g., "deploy/helm/myapp/Chart.yaml"
  # Release workflow (optional) — for nightly/weekly release checks
  release_workflow: ""                  # e.g., "Release"

outreach:                               # optional — only if outreach agent is enabled
  enabled: false
  description: ""                       # one-line project description for directory submissions
  differentiators: []                   # key selling points
  target_placements: 0                  # awesome-list placement goal
  coverage_badge_url: ""                # gist URL for coverage badge JSON
  ga4:
    property_id: ""                     # GA4 property ID
    service_account_key: ""             # path to GA4 service account JSON

dashboard:
  title: ""                             # auto-generated as "{project.name} Hive" if empty
  port: 3001
